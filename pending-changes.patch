From 9ed954bbee8002048411317aed5265b619fe523b Mon Sep 17 00:00:00 2001
From: AEMY Studio <noreply@aemy.studio>
Date: Tue, 21 Apr 2026 11:40:50 +0000
Subject: [PATCH 2/2] Style columns block with yellow border cards matching AA
 Insurance design

Adds yellow (#ffd400) border, 4px radius, 16px padding to column cells.
Matches the original .content-block__yellow__ffd700 pattern used for
Stay safe / Stay away / Stay informed cards on /prepare page.

Co-Authored-By: Claude Opus 4.6 <noreply@anthropic.com>
---
 blocks/columns/columns.css | 34 ++++++++++++++++++++++++++++++++--
 1 file changed, 32 insertions(+), 2 deletions(-)

diff --git a/blocks/columns/columns.css b/blocks/columns/columns.css
index f2b203e..1c9bf25 100644
--- a/blocks/columns/columns.css
+++ b/blocks/columns/columns.css
@@ -1,6 +1,11 @@
+/* Columns block — AA Insurance style
+   Reference: /prepare page "Stay safe / Stay away / Stay informed" cards
+   Original uses .content-block__yellow__ffd700 with 1px yellow border + 16px padding */
+
 .columns > div {
   display: flex;
   flex-direction: column;
+  gap: 16px;
 }
 
 .columns img {
@@ -9,10 +14,35 @@
 
 .columns > div > div {
   order: 1;
+  border: 1px solid var(--aa-yellow, #ffd400);
+  border-radius: 4px;
+  padding: 16px;
+}
+
+.columns > div > div > h3 {
+  color: var(--text-color, #262626);
+  font-family: Arial, sans-serif;
+  font-size: 1.5rem;
+  font-weight: 700;
+  line-height: 1.75rem;
+  margin: 0 0 8px;
+}
+
+.columns > div > div > p {
+  color: var(--text-color, #262626);
+  font-size: 1rem;
+  line-height: 1.5rem;
+  margin: 0 0 8px;
+}
+
+.columns > div > div > p:last-child {
+  margin-bottom: 0;
 }
 
 .columns > div > .columns-img-col {
   order: 0;
+  border: none;
+  padding: 0;
 }
 
 .columns > div > .columns-img-col img {
@@ -21,8 +51,8 @@
 
 @media (width >= 900px) {
   .columns > div {
-    align-items: center;
-    flex-direction: unset;
+    align-items: stretch;
+    flex-direction: row;
     gap: 24px;
   }
 
-- 
